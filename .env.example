# Sanity — public project coordinates (safe to expose; inlined into the client bundle).
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=
PUBLIC_SANITY_API_VERSION=

# Sanity API token with READ access (drafts included).
# Two secret worlds (see AGENTS.md):
#   - Node scripts (seed/import/migrate) read this from `.env` via dotenv.
#   - The Worker runtime ALSO needs it — for the /api/generate-description
#     endpoint's server-side DRAFT read — so add the same token to `.dev.vars`
#     locally and `wrangler secret put SANITY_TOKEN` in production.
SANITY_TOKEN=
