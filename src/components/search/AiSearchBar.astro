---
/**
 * Hero AI search bar (Phase 3a) — the PRIMARY homepage interface.
 *
 * A plain-English input with a cycling typewriter placeholder that POSTs to
 * /api/search and shows the AI's interpretation beneath the bar. It is a
 * JS-only enhancement: there is intentionally no <form method="GET">. With JS
 * disabled, the classic filter drawer — reachable via the subordinated
 * "Or refine manually" link below, which IS the drawer's trigger (id
 * "filters-trigger", wired through FilterDrawer's existing triggerId prop) —
 * is the interface. The drawer is not duplicated here.
 *
 * SCOPE (Phase 3a): the extracted filters are DISPLAYED ONLY, never APPLIED.
 * This bar does not touch the URL or the grid. Phase 3c wires filter
 * application; Phase 3b morphs this into the chat widget. The readback exists
 * purely to prove the pipeline end-to-end and to let us judge the typewriter
 * cadence and visual hierarchy in isolation.
 *
 * Dealer-scoped copy and timings come from dealerConfig.aiSearch (Decision 1);
 * nothing here is hardcoded. Submit affordance is a labelled "Search" button
 * (not an icon alone) — for a novel AI interface an explicit verb reads clearer.
 */
import { dealerConfig } from '../../config/dealer';
import { iconSvg } from '../../lib/listing';

interface Props {
  /** Active filter count — drives the badge on the "Or refine manually" trigger. */
  activeCount: number;
}
const { activeCount } = Astro.props;

const { placeholders, fallbackLinkLabel, typewriterDwellMs, typewriterTypeMs, typewriterDeleteMs } =
  dealerConfig.aiSearch;

// Placeholders + timings travel to the inline script via data-* (the same
// pattern FilterDrawer uses with data-default-sort), so the script reads dealer
// config without re-importing it.
const timing = JSON.stringify({
  dwell: typewriterDwellMs,
  type: typewriterTypeMs,
  del: typewriterDeleteMs,
});
---

<section
  data-ai-search
  data-timing={timing}
  data-placeholders={JSON.stringify(placeholders)}
  class="mx-auto max-w-2xl"
>
  <!-- Hero input -->
  <div class="relative">
    <input
      type="text"
      data-ai-input
      autocomplete="off"
      enterkeyhint="search"
      aria-label="Describe the car you want, in plain English"
      class="w-full rounded-2xl border border-slate-200 bg-white py-4 pl-5 pr-32 text-lg text-slate-900 shadow-sm transition placeholder:text-slate-400 focus:border-slate-400 focus:shadow-md focus:outline-none"
    />
    <button
      type="button"
      data-ai-submit
      class="absolute right-2 top-1/2 inline-flex -translate-y-1/2 items-center gap-2 rounded-xl bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-slate-700 disabled:opacity-70"
    >
      <span
        data-ai-spinner
        hidden
        aria-hidden="true"
        class="h-4 w-4 animate-spin rounded-full border-2 border-white/40 border-t-white"
      ></span>
      <span data-ai-submit-label class="inline-flex items-center gap-1.5">
        Search
        <Fragment set:html={iconSvg('arrow', 'h-3.5 w-3.5')} />
      </span>
    </button>
  </div>

  <!-- Subordinated fallback link = the classic drawer's trigger (with active-filter badge) -->
  <div class="mt-3 text-center">
    <button
      type="button"
      id="filters-trigger"
      class="inline-flex items-center gap-1.5 text-sm font-medium text-slate-500 underline-offset-2 transition hover:text-slate-900 hover:underline"
    >
      {fallbackLinkLabel}
      <span
        data-filter-count
        hidden={activeCount === 0}
        class="inline-flex min-w-5 items-center justify-center rounded-full bg-slate-900 px-1.5 py-0.5 text-xs font-semibold text-white no-underline"
      >
        {activeCount}
      </span>
    </button>
  </div>

  <!-- Readback (built by JS after submit). DISPLAY ONLY — never applied to the
       URL or grid in Phase 3a (see header comment). -->
  <div data-ai-readback hidden aria-live="polite" class="mt-6"></div>
</section>

<script>
  // Vanilla inline enhancement, matching CompareTray/FilterDrawer idiom. Wrapped
  // in an IIFE so early returns are legal in a module script.
  (() => {
    const root = document.querySelector('[data-ai-search]') as HTMLElement | null;
    if (!root) return;
    const input = root.querySelector('[data-ai-input]') as HTMLInputElement | null;
    const submitBtn = root.querySelector('[data-ai-submit]') as HTMLButtonElement | null;
    const spinner = root.querySelector('[data-ai-spinner]') as HTMLElement | null;
    const submitLabel = root.querySelector('[data-ai-submit-label]') as HTMLElement | null;
    const readback = root.querySelector('[data-ai-readback]') as HTMLElement | null;
    if (!input || !submitBtn || !spinner || !submitLabel || !readback) return;

    const placeholders: string[] = JSON.parse(root.dataset.placeholders || '[]');
    const t = JSON.parse(root.dataset.timing || '{}') as { dwell: number; type: number; del: number };

    // --- Typewriter placeholder (setTimeout-based) --------------------------
    let phIndex = 0;
    let charIndex = 0;
    let deleting = false;
    let paused = false;
    let timer: ReturnType<typeof setTimeout> | null = null;
    const clear = () => {
      if (timer) clearTimeout(timer);
      timer = null;
    };
    function tick() {
      if (paused || placeholders.length === 0) return;
      const full = placeholders[phIndex] || '';
      if (!deleting) {
        charIndex = Math.min(charIndex + 1, full.length);
        input!.placeholder = full.slice(0, charIndex);
        if (charIndex >= full.length) {
          deleting = true;
          timer = setTimeout(tick, t.dwell);
          return;
        }
        timer = setTimeout(tick, t.type);
      } else {
        charIndex = Math.max(charIndex - 1, 0);
        input!.placeholder = full.slice(0, charIndex);
        if (charIndex <= 0) {
          deleting = false;
          phIndex = (phIndex + 1) % placeholders.length;
          timer = setTimeout(tick, t.type);
          return;
        }
        timer = setTimeout(tick, t.del);
      }
    }
    // Focus pauses (keeping position); blurring an empty input resumes from there.
    input.addEventListener('focus', () => {
      paused = true;
      clear();
    });
    input.addEventListener('blur', () => {
      // Resume from where it paused if the field was left empty.
      if (!input.value.trim() && paused) {
        paused = false;
        clear();
        tick();
      }
    });
    tick(); // starts (input is empty + unfocused on load)

    // --- Submit → POST /api/search → readback (DISPLAY ONLY) ----------------
    const GENERIC_ERROR = "I couldn't understand that — try rephrasing, or use manual filters.";
    const RATE_ERROR = "You're doing that a lot — try again in a moment.";
    let seq = 0;

    function setLoading(on: boolean) {
      submitBtn!.disabled = on;
      spinner!.hidden = !on;
      submitLabel!.hidden = on;
    }

    async function submit() {
      const query = input!.value.trim();
      if (!query) return;
      const my = ++seq; // supersede any in-flight response
      setLoading(true);
      try {
        const res = await fetch('/api/search', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ query }),
        });
        if (my !== seq) return;
        if (res.status === 429) return renderError(RATE_ERROR);
        if (!res.ok) return renderError(GENERIC_ERROR);
        const data = await res.json();
        if (my !== seq) return;
        renderReadback(data);
      } catch {
        if (my === seq) renderError(GENERIC_ERROR);
      } finally {
        if (my === seq) setLoading(false);
      }
    }

    submitBtn.addEventListener('click', submit);
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        submit();
      }
    });

    // --- Rendering (DOM-built; LLM free-text via textContent, never innerHTML) --
    // Chip visual reused from ActiveFilterChips.astro — one chip language site-wide.
    const CHIP =
      'inline-flex items-center gap-1.5 rounded-full bg-slate-900/5 px-3 py-1 text-xs font-medium text-slate-600 ring-1 ring-slate-900/10';
    const CONF: Record<string, string> = {
      high: 'bg-emerald-50 text-emerald-700 ring-emerald-200',
      medium: 'bg-amber-50 text-amber-700 ring-amber-200',
      low: 'bg-slate-100 text-slate-600 ring-slate-200',
    };

    function el(tag: string, cls?: string, text?: string): HTMLElement {
      const n = document.createElement(tag);
      if (cls) n.className = cls;
      if (text != null) n.textContent = text;
      return n;
    }
    function show(node: HTMLElement) {
      readback!.replaceChildren(node);
      readback!.hidden = false;
    }
    function renderError(msg: string) {
      show(
        el('div', 'rounded-2xl border border-slate-200 bg-white px-5 py-4 text-left text-sm text-slate-600', msg),
      );
    }

    const titleCase = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);
    const fmtInt = (n: number) => Number(n).toLocaleString();
    function rangeLabel(min: number | null, max: number | null, fmt: (v: number) => string): string {
      if (min != null && max != null) return `${fmt(min)} – ${fmt(max)}`;
      if (min != null) return `From ${fmt(min)}`;
      return `Up to ${fmt(max as number)}`;
    }
    // Build display chips from the returned FilterState (label:value pairs).
    function filterChips(f: any): string[] {
      const out: string[] = [];
      const dims: [string, string][] = [
        ['bodyType', 'Body'],
        ['transmission', 'Transmission'],
        ['fuelType', 'Fuel'],
        ['driveType', 'Drive'],
        ['condition', 'Condition'],
      ];
      for (const [k, label] of dims)
        (f?.[k] || []).forEach((v: string) => out.push(`${label}: ${titleCase(String(v))}`));
      (f?.seats || []).forEach((s: number) => out.push(`Seats: ${s}`));
      if (f?.priceMin != null || f?.priceMax != null)
        out.push('Price: ' + rangeLabel(f.priceMin, f.priceMax, (v) => '$' + fmtInt(v)));
      if (f?.yearMin != null || f?.yearMax != null)
        out.push('Year: ' + rangeLabel(f.yearMin, f.yearMax, (v) => String(v)));
      if (f?.odoMax != null) out.push(`Odometer: ≤ ${fmtInt(f.odoMax)} km`);
      return out;
    }
    function chipRow(items: string[]): HTMLElement {
      const ul = el('ul', 'flex flex-wrap gap-2');
      items.forEach((txt) => {
        const li = document.createElement('li');
        li.appendChild(el('span', CHIP, txt));
        ul.appendChild(li);
      });
      return ul;
    }
    function labeledRow(label: string, valueNode: HTMLElement): HTMLElement {
      const row = el('div', 'flex flex-col gap-1.5 sm:flex-row sm:items-baseline sm:gap-3');
      row.appendChild(
        el('span', 'w-28 shrink-0 text-xs font-semibold uppercase tracking-wide text-slate-400', label),
      );
      const val = el('div', 'flex-1');
      val.appendChild(valueNode);
      row.appendChild(val);
      return row;
    }

    function renderReadback(data: any) {
      const card = el(
        'div',
        'space-y-4 rounded-2xl border border-slate-200 bg-white px-5 py-5 text-left shadow-sm',
      );
      card.appendChild(labeledRow('AI understood', el('p', 'text-slate-800', data?.interpretation || '—')));

      const conf = String(data?.confidence || 'low');
      card.appendChild(
        labeledRow(
          'Confidence',
          el(
            'span',
            `inline-flex rounded-full px-2.5 py-1 text-xs font-semibold uppercase tracking-wide ring-1 ring-inset ${CONF[conf] || CONF.low}`,
            conf,
          ),
        ),
      );

      // Low confidence + a clarifying question → ask it instead of showing filters.
      if (conf === 'low' && data?.clarifyingQuestion) {
        const q = el(
          'div',
          'rounded-xl bg-slate-50 px-4 py-3 text-slate-800 ring-1 ring-inset ring-slate-200',
          String(data.clarifyingQuestion),
        );
        card.appendChild(labeledRow('One question', q));
      } else {
        const fchips = filterChips(data?.filters);
        card.appendChild(
          labeledRow(
            'Filters found',
            fchips.length ? chipRow(fchips) : el('span', 'text-sm text-slate-400', 'None'),
          ),
        );
        const reasons: string[] = Array.isArray(data?.matchReasons) ? data.matchReasons : [];
        if (reasons.length) card.appendChild(labeledRow('Match reasons', chipRow(reasons)));
      }

      card.appendChild(
        el('p', 'text-xs text-slate-400', 'Preview only — these filters aren’t applied to the grid yet.'),
      );
      show(card);
    }
  })();
</script>
