---
import '../../styles/global.css';
import { client } from '../../sanity/lib/client';
import { urlFor } from '../../sanity/lib/image';
import ListingCard from '../../components/ListingCard.astro';
import ContactModal from '../../components/ContactModal.astro';
import CompareTray from '../../components/CompareTray.astro';
import ChatWidget from '../../components/widgets/ChatWidget.astro';
import { PortableText } from 'astro-portabletext';
import {
  type Listing,
  LISTING_FIELDS,
  iconSvg,
  detailIconName,
  categoryIconName,
  detailDisplay,
  statusConfig,
  formatPrice,
  categoryLabel,
  formatDate,
} from '../../lib/listing';

export async function getStaticPaths() {
  const slugs = await client.fetch<{ slug: string }[]>(
    `*[_type == "listing" && defined(slug.current)]{ "slug": slug.current }`,
  );
  return slugs.map((s) => ({ params: { slug: s.slug } }));
}

const { slug } = Astro.params;

const listing = await client.fetch<Listing | null>(
  `*[_type == "listing" && slug.current == $slug][0]{ ${LISTING_FIELDS} }`,
  { slug },
);

if (!listing) {
  return Astro.redirect('/404');
}

const related = await client.fetch<Listing[]>(
  `*[_type == "listing" && category == $category && slug.current != $slug]
     | order(listingDate desc)[0...3]{ ${LISTING_FIELDS} }`,
  { category: listing.category, slug },
);

const images = listing.images ?? [];
const mainImage = images[0]
  ? urlFor(images[0]).width(900).height(675).fit('crop').auto('format').url()
  : null;

const status = statusConfig[listing.status] ?? statusConfig.draft;
const categoryName = categoryLabel(listing.category);
const priceLabel = formatPrice(listing.price, listing.currency);
const details = listing.details ?? [];

const REPO = 'https://github.com/alex-boop-chasey/astro-listings-demo';

// Derive the social description from the first Portable Text paragraph.
const firstBlockText = Array.isArray(listing.description)
  ? (() => {
      const block = listing.description.find((b: any) => b?._type === 'block') as any;
      return block ? (block.children ?? []).map((c: any) => c?.text ?? '').join('').trim() : '';
    })()
  : '';
const metaDescription = firstBlockText || `${listing.title} — ${categoryName} listing.`;
const canonicalURL = new URL(
  Astro.url.pathname,
  Astro.site ?? 'https://astro-listings-demo.pages.dev',
).href;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{listing.title} · astro-listings</title>
    <meta name="description" content={metaDescription} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={listing.title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalURL} />
    <!-- TODO: add <meta property="og:image"> once the demo is deployed and an OG image is hosted.
         Required for social previews — summary_large_image cards render blank without it. -->

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={listing.title} />
    <meta name="twitter:description" content={metaDescription} />
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-800 antialiased text-[15px] leading-relaxed">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-lg focus:bg-slate-900 focus:px-4 focus:py-2 focus:text-white"
    >
      Skip to content
    </a>

    <!-- Sticky nav -->
    <header class="sticky top-0 z-40 border-b border-slate-200 bg-white/80 backdrop-blur">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
        <a href="/" class="text-base font-semibold tracking-tight text-slate-900">
          astro<span class="text-slate-400">-listings</span>
        </a>
        <a
          href="/"
          class="inline-flex items-center gap-1.5 text-sm text-slate-500 transition hover:text-slate-900"
        >
          <Fragment set:html={iconSvg('arrowLeft', 'h-4 w-4')} />
          All listings
        </a>
      </div>
    </header>

    <div class="mx-auto max-w-7xl px-6">
      <main id="main-content" tabindex="-1">
      <!-- Breadcrumb -->
      <nav class="py-6 text-sm text-slate-500" aria-label="Breadcrumb">
        <a href="/" class="transition hover:text-slate-900">Home</a>
        <span class="px-1.5 text-slate-300">/</span>
        <span>{categoryName}</span>
        <span class="px-1.5 text-slate-300">/</span>
        <span class="text-slate-700">{listing.title}</span>
      </nav>

      <!-- Hero -->
      <section class="grid gap-8 lg:grid-cols-5">
        <!-- Gallery -->
        <div class="lg:col-span-3">
          <div class="relative aspect-[4/3] overflow-hidden rounded-2xl border border-slate-200 bg-slate-100">
            {
              mainImage ? (
                <img
                  id="main-image"
                  src={mainImage}
                  alt={listing.title}
                  class="h-full w-full object-cover"
                />
              ) : (
                <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-slate-100 to-slate-200 text-slate-400">
                  <Fragment set:html={iconSvg(categoryIconName(listing.category), 'h-16 w-16')} />
                </div>
              )
            }

            <span
              class:list={[
                'absolute right-3 top-3 rounded-full px-2.5 py-1 text-xs font-semibold uppercase tracking-wide text-white shadow',
                status.badge,
              ]}
            >
              {status.label}
            </span>

            {
              listing.status === 'sold' && (
                <div
                  aria-hidden="true"
                  class="pointer-events-none absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 -rotate-12 bg-red-600/95 px-20 py-2 text-center text-xl font-extrabold uppercase tracking-[0.3em] text-white shadow-lg"
                >
                  Sold
                </div>
              )
            }
          </div>

          {
            images.length > 1 && (
              <div class="mt-4 grid grid-cols-4 gap-3">
                {images.slice(0, 4).map((img) => (
                  <button
                    type="button"
                    data-full={urlFor(img).width(900).height(675).fit('crop').auto('format').url()}
                    class="overflow-hidden rounded-lg border border-slate-200 transition hover:border-slate-400"
                  >
                    <img
                      src={urlFor(img).width(200).height(150).fit('crop').auto('format').url()}
                      alt={`${listing.title} thumbnail`}
                      class="aspect-[4/3] h-full w-full object-cover"
                    />
                  </button>
                ))}
              </div>
            )
          }
        </div>

        <!-- Info -->
        <div class="lg:col-span-2">
          <div class="rounded-2xl border border-slate-200 bg-white p-6">
            <span class="inline-flex items-center gap-1.5 text-xs font-medium uppercase tracking-wide text-slate-500">
              <span class="text-slate-400">
                <Fragment set:html={iconSvg(categoryIconName(listing.category), 'h-3.5 w-3.5')} />
              </span>
              {categoryName}
            </span>

            <h1 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">
              {listing.title}
            </h1>

            <p class="mt-4 text-4xl font-bold text-slate-900">{priceLabel}</p>

            {
              listing.listingDate && (
                <p class="mt-2 text-sm text-slate-500">Listed on {formatDate(listing.listingDate)}</p>
              )
            }

            <div class="mt-6 flex flex-col gap-3">
              <button
                id="contact-btn"
                type="button"
                class="w-full rounded-xl bg-slate-900 px-5 py-3 text-center font-semibold text-white transition hover:bg-slate-700"
              >
                Contact Seller
              </button>
              <button
                id="save-btn"
                type="button"
                data-id={listing._id}
                aria-pressed="false"
                class="inline-flex w-full items-center justify-center gap-2 rounded-xl border border-slate-300 px-5 py-3 font-semibold text-slate-700 transition hover:bg-slate-50"
              >
                <span id="save-icon" class="inline-flex"><Fragment set:html={iconSvg('heart', 'h-4 w-4')} /></span>
                <span id="save-label">Save Listing</span>
              </button>
            </div>
          </div>
        </div>
      </section>

      <!-- Details -->
      {
        details.length > 0 && (
          <section class="py-16">
            <h2 class="text-xl font-bold text-slate-900">Details</h2>
            <div class="mt-6 grid grid-cols-2 gap-4 md:grid-cols-3 lg:grid-cols-4">
              {details.map((d) => (
                <div class="rounded-xl border border-slate-200 bg-white p-4">
                  <div class="text-slate-400">
                    {d.valueType === 'boolean' ? (
                      <Fragment
                        set:html={iconSvg(
                          d.valueBoolean ? 'check' : 'cross',
                          'h-5 w-5 ' + (d.valueBoolean ? 'text-emerald-600' : 'text-red-500'),
                        )}
                      />
                    ) : (
                      <Fragment set:html={iconSvg(detailIconName(d.label), 'h-5 w-5')} />
                    )}
                  </div>
                  <p class="mt-3 text-xs font-medium uppercase tracking-wide text-slate-500">
                    {d.label}
                  </p>
                  <p class="mt-1 text-lg font-semibold text-slate-900">{detailDisplay(d)}</p>
                </div>
              ))}
            </div>
          </section>
        )
      }

      <!-- Description -->
      {
        Array.isArray(listing.description) && listing.description.length > 0 && (
          <section class="border-t border-slate-200 py-16">
            <h2 class="text-xl font-bold text-slate-900">Description</h2>
            <div class="prose prose-slate mt-4 max-w-2xl">
              <PortableText value={listing.description as any} />
            </div>
          </section>
        )
      }

      <!-- Related -->
      {
        related.length > 0 && (
          <section class="border-t border-slate-200 py-16">
            <h2 class="text-xl font-bold text-slate-900">More from {categoryName}</h2>
            <div class="mt-6 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
              {related.map((r) => (
                <ListingCard listing={r} />
              ))}
            </div>
          </section>
        )
      }

      </main>

      <!-- Footer -->
      <footer class="mt-24 border-t border-slate-200 py-8 text-center text-sm text-slate-500">
        Built with Astro, Tailwind and Sanity ·
        <a href={REPO} target="_blank" rel="noopener noreferrer" class="underline transition hover:text-slate-900">
          View on GitHub
        </a>
      </footer>
    </div>

    <!-- Contact Seller demo modal (self-contained, wired to #contact-btn) -->
    <ContactModal />

    <!-- Floating comparison tray (self-contained, appears when ≥1 selected) -->
    <CompareTray />

    <!-- Floating AI chat assistant (Rebi) — self-contained global overlay -->
    <ChatWidget />

    <script>
      import { icons } from '../../lib/listing';

      // --- Gallery thumbnail switching -------------------------------------
      const main = document.getElementById('main-image') as HTMLImageElement | null;
      document.querySelectorAll<HTMLElement>('[data-full]').forEach((thumb) => {
        thumb.addEventListener('click', () => {
          if (main && thumb.dataset.full) main.src = thumb.dataset.full;
        });
      });

      // --- Save Listing (persisted in localStorage) ------------------------
      const SAVED_KEY = 'astro-listings-saved';
      const saveBtn = document.getElementById('save-btn');
      const saveIcon = document.getElementById('save-icon');
      const saveLabel = document.getElementById('save-label');
      const listingId = saveBtn?.dataset.id;

      const filledHeart = `<svg class="h-4 w-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">${icons.heart}</svg>`;
      const outlineHeart = `<svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${icons.heart}</svg>`;

      function getSaved(): string[] {
        try {
          const raw = localStorage.getItem(SAVED_KEY);
          return raw ? JSON.parse(raw) : [];
        } catch {
          return [];
        }
      }

      function renderSaved() {
        if (!saveBtn || !saveIcon || !saveLabel || !listingId) return;
        const saved = getSaved().includes(listingId);
        saveIcon.innerHTML = saved ? filledHeart : outlineHeart;
        saveLabel.textContent = saved ? 'Saved' : 'Save Listing';
        saveBtn.classList.toggle('bg-slate-100', saved);
        saveBtn.setAttribute('aria-pressed', String(saved));
      }

      saveBtn?.addEventListener('click', () => {
        if (!listingId) return;
        try {
          const list = getSaved();
          const idx = list.indexOf(listingId);
          if (idx >= 0) list.splice(idx, 1);
          else list.push(listingId);
          localStorage.setItem(SAVED_KEY, JSON.stringify(list));
        } catch {
          /* localStorage unavailable — no-op */
        }
        renderSaved();
      });
      renderSaved();
    </script>
  </body>
</html>
