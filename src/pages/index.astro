---
// SSR (not prerendered): the homepage reads filter/pagination params from the
// URL and filters server-side, so it can't be baked at build time. Mirrors
// compare.astro, which opts into SSR the same way.
export const prerender = false;

import '../styles/global.css';
import { client } from '../sanity/lib/client';
import CompareTray from '../components/CompareTray.astro';
import ChatWidget from '../components/widgets/ChatWidget.astro';
import FilterDrawer from '../components/filters/FilterDrawer.astro';
import InventoryResults from '../components/filters/InventoryResults.astro';
import AiSearchBar from '../components/search/AiSearchBar.astro';
import { dealerConfig } from '../config/dealer';
import { iconSvg } from '../lib/listing';
import {
  parseFilters,
  buildListingsQuery,
  activeChips,
  type InventoryResult,
} from '../lib/listings-query';

// Feature flag read at BUILD/render time (not probed at runtime): when AI search
// is off, the hero bar doesn't render at all and the classic Filters button
// (below) is the only interface.
const aiEnabled = dealerConfig.ai.search.enabled;

// Edge caching (DECISION.md Decision 5): anonymous/unfiltered hits get served
// from Cloudflare's cache and feel static; each unique filter URL caches
// separately. Recovers most of the TTFB we'd otherwise lose by dropping
// prerender.
Astro.response.headers.set('Cache-Control', 'public, s-maxage=60, stale-while-revalidate=300');

// URL is the single source of truth. Parse the filter state, then filter +
// paginate server-side via the shared query builder (reused by the partial).
const filterState = parseFilters(Astro.url.searchParams);
const { query, params } = buildListingsQuery(filterState);
const { items: listings, total } = await client.fetch<InventoryResult>(query, params);

const activeCount = activeChips(filterState).length;
const year = new Date().getFullYear();

const title = 'Rebirth Listings Auto — quality vehicles, ready to drive away';
const description =
  'Browse the current range at Rebirth Listings Auto. Every vehicle in our inventory, kept up to date — find your next car and talk to our team.';
const canonicalURL = new URL(
  Astro.url.pathname,
  Astro.site ?? 'https://rebirth-listings-auto.pages.dev',
).href;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <!-- TODO: add <meta property="og:image"> once the demo is deployed and an OG image is hosted.
         Required for social previews — summary_large_image cards render blank without it. -->

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-800 antialiased text-[15px] leading-relaxed">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-lg focus:bg-slate-900 focus:px-4 focus:py-2 focus:text-white"
    >
      Skip to content
    </a>

    <div class="mx-auto max-w-7xl px-6">
      <!-- Header -->
      <header class="flex items-center justify-between py-6">
        <a href="/" class="text-base font-semibold tracking-tight text-slate-900">
          Rebirth Listings<span class="text-slate-400"> Auto</span>
        </a>
        <nav class="flex items-center gap-6 text-sm">
          <a href="#inventory" class="text-slate-500 transition hover:text-slate-900">
            Inventory
          </a>
          <a
            href="#"
            id="nav-contact"
            class="text-slate-500 transition hover:text-slate-900"
          >
            Contact
          </a>
        </nav>
      </header>

      <main id="main-content" tabindex="-1">
        <!-- Hero -->
        <section class="mx-auto max-w-3xl pt-16 pb-8 text-center md:pt-24 md:pb-10">
          <span
            class="inline-flex items-center gap-1.5 rounded-full bg-slate-900/5 px-3 py-1 text-xs font-medium text-slate-600 ring-1 ring-slate-900/10"
          >
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
            In stock now
          </span>
          <h1 class="mt-6 text-4xl font-bold tracking-tight text-slate-900 md:text-6xl">
            Your next car is waiting.
          </h1>
          <p class="mx-auto mt-5 max-w-2xl text-lg text-slate-600">
            Browse the current range at Rebirth Listings Auto — quality vehicles, full specs,
            and a team ready to help you drive away happy.
          </p>
        </section>

        <!-- Hero AI search bar (Phase 3a) — primary interface when enabled. -->
        {
          aiEnabled && (
            <div class="pb-16 md:pb-20">
              <AiSearchBar activeCount={activeCount} />
            </div>
          )
        }

        {/* Inventory heading. When AI is on, the drawer trigger is the AI bar's
            "Or refine manually" link; only when AI is off does the classic
            Filters button render here (same id="filters-trigger"). */}
        <div id="inventory" class="flex items-end justify-between border-b border-slate-200 pb-4">
          <h2 class="text-xl font-semibold tracking-tight text-slate-900">Current inventory</h2>
          {
            !aiEnabled && (
              <button
                type="button"
                id="filters-trigger"
                class="inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm transition hover:bg-slate-50"
              >
                <Fragment set:html={iconSvg('filter', 'h-4 w-4')} />
                Filters
                <span
                  data-filter-count
                  hidden={activeCount === 0}
                  class="inline-flex min-w-5 items-center justify-center rounded-full bg-slate-900 px-1.5 py-0.5 text-xs font-semibold text-white"
                >
                  {activeCount}
                </span>
              </button>
            )
          }
        </div>

        <!-- Filter drawer (persistent; lives outside the swappable results) -->
        <FilterDrawer state={filterState} triggerId="filters-trigger" />

        <!-- Swappable inventory results (chips + grid + pagination) -->
        <InventoryResults listings={listings} total={total} state={filterState} />
      </main>

      <!-- Footer -->
      <footer class="mt-24 border-t border-slate-200 py-8 text-center text-sm text-slate-500">
        © {year} Rebirth Listings Auto · All vehicles subject to availability.
      </footer>
    </div>

    <!-- Floating comparison tray (self-contained, appears when ≥1 selected) -->
    <CompareTray />

    <!-- Floating AI chat assistant (Rebi) — self-contained global overlay -->
    <ChatWidget />

    <script>
      // "Contact" in the nav opens the floating chat assistant.
      document.getElementById('nav-contact')?.addEventListener('click', (e) => {
        e.preventDefault();
        document.getElementById('reb-launcher')?.click();
      });
    </script>
  </body>
</html>
